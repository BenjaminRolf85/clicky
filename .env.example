# Clicky — optional handoff configuration
# Copy to .env next to Clicky.app and fill in the values you need.
# All entries are optional — omit any tool you don't have installed.

# ── Codex CLI ──────────────────────────────────────────────────────────────
# CODEX_COMMAND=codex
# CODEX_WORKDIR=/Users/you/projects/playground
# CODEX_TIMEOUT_SECONDS=900

# ── Claude Code CLI ────────────────────────────────────────────────────────
# CLAUDE_CODE_COMMAND=claude
# CLAUDE_CODE_TIMEOUT_SECONDS=900

# ── OpenClaw ───────────────────────────────────────────────────────────────
# OPENCLAW_COMMAND=openclaw
# OPENCLAW_SESSION_KEY=main
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:41513
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
# OPENCLAW_TIMEOUT_SECONDS=120
